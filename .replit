modules = ["nodejs-20"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AquaVera Admin Panel"

[[workflows.workflow]]
name = "AquaVera Admin Panel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/aquavera-admin run dev"
waitForPort = 24854

[workflows.workflow.metadata]
outputType = "webview"
