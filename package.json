{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm -r --filter @workspace/api-server --filter @workspace/aquavera-admin --parallel run dev",
    "build": "pnpm run typecheck && pnpm run build:unified",
    "build:unified": "pnpm -F @workspace/aquavera-admin build && pnpm -F @workspace/api-server build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -F @workspace/aquavera-admin -F @workspace/api-server --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "@types/node": "catalog:"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
